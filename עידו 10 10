<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Naomi's English SAT</title>
    
    <!-- Firebase SDKs -->
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>
    
    <!-- UI & Styles -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap');
        
        body { 
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            color: #000000;
            overflow-x: hidden;
        }

        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(10px);
            z-index: 100;
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #f9f9f9;
        }

        .nav-left { display: flex; gap: 12px; align-items: center; order: 1; }
        .nav-right { display: flex; align-items: center; gap: 12px; order: 2; }

        .logo-box {
            width: 32px;
            height: 32px;
            background: #000;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            border-radius: 6px;
            font-size: 14px;
        }

        .nav-brand-text {
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.15em;
        }

        .hero-section {
            padding-top: 180px;
            padding-bottom: 60px;
            text-align: center;
        }

        .hero-title {
            font-size: clamp(2.5rem, 6vw, 4.5rem);
            font-weight: 900;
            letter-spacing: -0.02em;
            color: #000;
            margin-bottom: 16px;
        }

        .hero-subtitle {
            font-size: 14px;
            font-weight: 600;
            color: #666;
            margin-bottom: 60px;
        }

        .upgrade-link {
            color: #000;
            text-decoration: underline;
            font-weight: 800;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .upgrade-link:hover { opacity: 0.7; }

        .material-grid {
            max-width: 600px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .material-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 16px;
        }

        .material-card {
            background: #ffffff;
            border: 1.5px solid #f0f0f0;
            border-radius: 14px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .material-card:hover:not(.locked) {
            border-color: #000;
            background: #fafafa;
        }

        .material-card.locked {
            opacity: 0.5;
            background: #fcfcfc;
        }

        .material-card span {
            font-weight: 700;
            font-size: 14px;
        }

        .lock-icon {
            position: absolute;
            top: 10px;
            right: 12px;
            font-size: 10px;
            color: #bbb;
        }

        .nav-btn {
            padding: 8px 20px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: all 0.2s;
        }

        .nav-btn-outline { border: 1.5px solid #000; color: #000; }
        .nav-btn-solid { background: #000; color: #fff; }
        
        .hidden { display: none !important; }
        .modal-bg { background: rgba(0,0,0,0.05); backdrop-filter: blur(8px); }

        /* Small centered modal style */
        .compact-modal {
            background: white;
            width: 100%;
            max-width: 360px;
            border-radius: 32px;
            padding: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
            border: 1px solid rgba(0,0,0,0.05);
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from { transform: translateY(20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        @media (max-width: 640px) {
            .material-row { grid-template-columns: 1fr; }
            nav { padding: 15px 20px; }
        }
    </style>
</head>
<body>

    <nav>
        <div class="nav-left">
            <div class="logo-box">N</div>
            <span class="nav-brand-text">NAOMI ENGLISH SAT</span>
        </div>

        <div class="nav-right">
            <div id="logged-out-nav" class="flex gap-2">
                <button onclick="openAuth(false)" class="nav-btn nav-btn-outline">Login</button>
                <button onclick="openAuth(true)" class="nav-btn nav-btn-solid">Sign Up</button>
            </div>
            <div id="logged-in-nav" class="hidden flex items-center gap-4">
                <span id="user-display" class="text-[9px] font-black uppercase tracking-widest text-gray-400"></span>
                <button onclick="logout()" class="text-gray-300 hover:text-red-500 text-sm"><i class="fas fa-sign-out-alt"></i></button>
            </div>
        </div>
    </nav>

    <section class="hero-section">
        <h1 class="hero-title">Naomi's English SAT</h1>
        <p class="hero-subtitle">
            Tests 1 & 2 solutions are free — 
            <span class="upgrade-link" onclick="handleUpgradeClick()">get full access for $250/year</span>
        </p>

        <div id="materials-list" class="material-grid">
            <div class="py-10 text-gray-400 text-xs font-bold uppercase tracking-widest">Loading Materials...</div>
        </div>
    </section>

    <!-- Auth Modal -->
    <div id="auth-modal" class="fixed inset-0 z-[200] hidden flex items-center justify-center modal-bg p-6">
        <div class="compact-modal relative">
            <button onclick="closeAuth()" class="absolute top-6 right-6 text-gray-300 hover:text-black"><i class="fas fa-times"></i></button>
            <h3 id="modal-title" class="text-xl font-black mb-1">Access</h3>
            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-6">Secure Portal</p>
            <form id="auth-form" class="space-y-3">
                <input type="email" id="email" placeholder="Email" class="w-full p-4 bg-gray-50 rounded-2xl text-sm outline-none" required>
                <input type="password" id="pass" placeholder="Password" class="w-full p-4 bg-gray-50 rounded-2xl text-sm outline-none" required>
                <div id="signup-fields" class="hidden">
                    <input type="password" id="pass-confirm" placeholder="Confirm Password" class="w-full p-4 bg-gray-50 rounded-2xl text-sm outline-none mt-3">
                </div>
                <p id="error-msg" class="hidden text-[9px] font-bold text-red-500 uppercase text-center py-2"></p>
                <button type="submit" class="w-full bg-black text-white py-4 rounded-2xl font-black text-xs uppercase tracking-widest mt-2">Continue</button>
            </form>
            <button onclick="toggleAuthMode()" id="toggle-btn" class="w-full mt-4 text-[9px] font-black text-gray-300 uppercase tracking-widest hover:text-black">New? Sign Up</button>
        </div>
    </div>

    <!-- Compact Payment Modal -->
    <div id="profile-modal" class="fixed inset-0 z-[210] hidden flex items-center justify-center modal-bg p-6">
        <div class="compact-modal relative text-center">
            <button onclick="document.getElementById('profile-modal').classList.add('hidden')" class="absolute top-6 right-6 text-gray-300 hover:text-black"><i class="fas fa-times"></i></button>
            
            <div class="mb-4 inline-flex items-center justify-center w-10 h-10 bg-black text-white rounded-xl">
                <i class="fas fa-crown text-sm"></i>
            </div>
            
            <h3 class="text-xl font-black mb-1">Premium</h3>
            <p class="text-[9px] font-bold text-gray-400 uppercase tracking-widest mb-6">Full Year Access</p>

            <div class="bg-gray-50 p-6 rounded-3xl mb-6">
                <div class="text-3xl font-black mb-0">$250</div>
                <div class="text-[8px] font-bold text-gray-400 uppercase tracking-tighter">Billed Annually</div>
            </div>

            <div class="text-left mb-6">
                <label class="flex items-start gap-3 cursor-pointer group">
                    <input type="checkbox" id="terms-check" onchange="togglePayButton()" class="mt-1 accent-black h-4 w-4">
                    <span class="text-[10px] font-bold text-gray-500 leading-tight">
                        I agree to the <span class="text-black underline cursor-pointer" onclick="event.stopPropagation(); showPolicy();">Terms & No-Refund Policy</span>.
                    </span>
                </label>
            </div>

            <div id="paypal-container" class="opacity-20 pointer-events-none transition-all duration-300">
                <a href="https://www.paypal.com/ncp/payment/Q3WJGWYM45VWA" target="_blank" class="block w-full bg-[#ffc439] text-[#003087] py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest">
                    Pay with PayPal
                </a>
            </div>
            <p id="checkbox-hint" class="text-[8px] font-black text-red-400 uppercase mt-3">Accept terms to proceed</p>
        </div>
    </div>

    <!-- Separate Policy Modal -->
    <div id="policy-modal" class="fixed inset-0 z-[250] hidden flex items-center justify-center modal-bg p-6">
        <div class="compact-modal relative max-w-sm">
            <button onclick="document.getElementById('policy-modal').classList.add('hidden')" class="absolute top-6 right-6 text-gray-300 hover:text-black"><i class="fas fa-times"></i></button>
            <h3 class="text-lg font-black mb-4 uppercase tracking-tight">Terms of Service</h3>
            <div class="text-[11px] text-gray-600 leading-relaxed text-left space-y-3">
                <p><strong>Subscription:</strong> Your membership grants full access to all materials for a period of 365 days from the time of purchase.</p>
                <p><strong>No-Refund Policy:</strong> Due to the immediate access to digital content, all sales are final. We do not offer refunds, returns, or exchanges under any circumstances once access is granted.</p>
                <p><strong>Usage:</strong> Content is for individual use only. Redistribution or account sharing is strictly prohibited and may result in account termination without refund.</p>
            </div>
            <button onclick="document.getElementById('policy-modal').classList.add('hidden')" class="w-full mt-6 bg-gray-100 py-3 rounded-xl font-black text-[9px] uppercase tracking-widest text-gray-500">I Understand</button>
        </div>
    </div>

    <!-- Viewer -->
    <div id="viewer" class="fixed inset-0 z-[300] hidden bg-white flex flex-col">
        <div class="p-4 border-b flex justify-between items-center px-8">
            <span id="viewer-name" class="text-[10px] font-black uppercase tracking-widest text-gray-400">Document</span>
            <button onclick="closeViewer()" class="bg-black text-white px-8 py-2 rounded-full text-[10px] font-black uppercase">Close</button>
        </div>
        <iframe id="pdf-frame" class="w-full h-full border-none"></iframe>
    </div>

    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyBGIT_bZ6nfoJjfipsPygC-BW9LoZeFflI",
            authDomain: "naomi-sat.firebaseapp.com",
            projectId: "cmds-36e71",
            storageBucket: "cmds-36e71.appspot.com",
            messagingSenderId: "1036067758252", 
            appId: "1:1036067758252:web:65e12f6a5e1d5a6b7d90c1"
        };
        firebase.initializeApp(firebaseConfig);
        const auth = firebase.auth();
        const db = firebase.firestore();

        let isPremium = false;
        let currentUser = null;
        let materialsData = [];
        let shouldOpenPayAfterLogin = false;

        async function fetchMaterials() {
            try {
                const snapshot = await db.collection('materials').orderBy('id', 'asc').get();
                materialsData = [];
                snapshot.forEach(doc => {
                    materialsData.push({ id: doc.id, ...doc.data() });
                });
                renderMaterials();
            } catch (err) { console.error("Error fetching materials:", err); }
        }

        auth.onAuthStateChanged(user => {
            currentUser = user;
            if (user) {
                db.collection('users').doc(user.uid).onSnapshot(doc => {
                    isPremium = doc.exists ? !!doc.data().isPremium : false;
                    renderMaterials();
                    updateNav(user);
                    if (shouldOpenPayAfterLogin) {
                        shouldOpenPayAfterLogin = false;
                        document.getElementById('profile-modal').classList.remove('hidden');
                    }
                });
            } else {
                isPremium = false;
                renderMaterials();
                updateNav(null);
            }
        });

        function renderMaterials() {
            const list = document.getElementById('materials-list');
            if (materialsData.length === 0) { fetchMaterials(); return; }
            list.innerHTML = '';
            for (let i = 0; i < materialsData.length; i += 2) {
                const item1 = materialsData[i];
                const item2 = materialsData[i+1];
                if(!item1) break;
                const row = document.createElement('div');
                row.className = 'material-row';
                const locked1 = !item1.free && !isPremium;
                const locked2 = item2 ? (!item2.free && !isPremium) : false;
                let html = `
                    <div class="material-card ${locked1 ? 'locked' : ''}" onclick="handleOpen('${item1.url}', '${item1.title}', ${locked1})">
                        ${locked1 ? '<i class="fas fa-lock lock-icon"></i>' : ''}
                        <span>${item1.title}</span>
                    </div>`;
                if(item2) {
                    html += `
                        <div class="material-card ${locked2 ? 'locked' : ''}" onclick="handleOpen('${item2.url}', '${item2.title}', ${locked2})">
                            ${locked2 ? '<i class="fas fa-lock lock-icon"></i>' : ''}
                            <span>${item2.title}</span>
                        </div>`;
                }
                row.innerHTML = html;
                list.appendChild(row);
            }
        }

        function handleUpgradeClick() {
            if (currentUser) {
                document.getElementById('profile-modal').classList.remove('hidden');
            } else {
                shouldOpenPayAfterLogin = true;
                openAuth(false);
            }
        }

        function togglePayButton() {
            const checked = document.getElementById('terms-check').checked;
            const container = document.getElementById('paypal-container');
            const hint = document.getElementById('checkbox-hint');
            if (checked) {
                container.style.opacity = '1';
                container.style.pointerEvents = 'auto';
                hint.classList.add('hidden');
            } else {
                container.style.opacity = '0.2';
                container.style.pointerEvents = 'none';
                hint.classList.remove('hidden');
            }
        }

        function showPolicy() {
            document.getElementById('policy-modal').classList.remove('hidden');
        }

        function updateNav(user) {
            const loggedOut = document.getElementById('logged-out-nav');
            const loggedIn = document.getElementById('logged-in-nav');
            if (user) {
                loggedOut.classList.add('hidden');
                loggedIn.classList.remove('hidden');
                document.getElementById('user-display').innerText = user.email;
            } else {
                loggedOut.classList.remove('hidden');
                loggedIn.classList.add('hidden');
            }
        }

        function handleOpen(url, title, locked) {
            if (locked) { handleUpgradeClick(); } 
            else {
                document.getElementById('viewer-name').innerText = title;
                document.getElementById('pdf-frame').src = url.includes('/view') ? url.replace(/\/view.*$/, '/preview') : url;
                document.getElementById('viewer').classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }
        }

        function openAuth(signup) {
            document.getElementById('auth-modal').classList.remove('hidden');
            document.getElementById('signup-fields').classList.toggle('hidden', !signup);
            document.getElementById('modal-title').innerText = signup ? "Sign Up" : "Login";
            document.body.style.overflow = 'hidden';
        }

        function toggleAuthMode() {
            const isCurrentlyLogin = document.getElementById('signup-fields').classList.contains('hidden');
            openAuth(isCurrentlyLogin);
        }

        function closeAuth() {
            document.getElementById('auth-modal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        document.getElementById('auth-form').onsubmit = async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const pass = document.getElementById('pass').value;
            const isSignUp = !document.getElementById('signup-fields').classList.contains('hidden');
            try {
                if (isSignUp) {
                    const confirm = document.getElementById('pass-confirm').value;
                    if (pass !== confirm) throw new Error("Passwords match error");
                    const cred = await auth.createUserWithEmailAndPassword(email, pass);
                    await db.collection('users').doc(cred.user.uid).set({ email, isPremium: false });
                } else {
                    await auth.signInWithEmailAndPassword(email, pass);
                }
                closeAuth();
            } catch (err) {
                document.getElementById('error-msg').innerText = err.message;
                document.getElementById('error-msg').classList.remove('hidden');
            }
        };

        function logout() { auth.signOut(); }
        function closeViewer() {
            document.getElementById('viewer').classList.add('hidden');
            document.getElementById('pdf-frame').src = '';
            document.body.style.overflow = 'auto';
        }
    </script>
</body>
</html>
